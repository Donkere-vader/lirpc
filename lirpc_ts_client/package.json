{
  "name": "lirpc_ts_client",
  "version": "0.1.0",
  "description": "TypeScript client for LiRPC (WebSocket transport)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/*.test.js",
    "typecheck:examples": "tsc -p tsconfig.examples.json"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.2"
  }
}
